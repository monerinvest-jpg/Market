# ============================================
# HandMade Market Backend — Environment Config
# ============================================

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=handmade_market

# --- JWT Security ---
# Генерируйте командой: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters-long
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# --- CORS (фронтенд URL) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App Settings ---
DEBUG=True
APP_TITLE=HandMade Market API
APP_VERSION=1.0.0
